{
  "name": "scipaper-todo",
  "private": true,
  "version": "1.0.0",
  "description": "SciPaper Todo desktop app for local-first scientific manuscript management.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node ./node_modules/concurrently/dist/bin/concurrently.js -k \"node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 5173\" \"node ./node_modules/wait-on/bin/wait-on tcp:5173 && node ./node_modules/cross-env/dist/bin/cross-env.js VITE_DEV_SERVER_URL=http://127.0.0.1:5173 node ./node_modules/electron/cli.js .\"",
    "build:renderer": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "build": "npm run build:renderer",
    "dist:win": "npm run build && node ./node_modules/electron-builder/cli.js --win nsis portable --x64",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "utif": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.nee.scipapertodo",
    "productName": "SciPaper Todo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
